<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile - KrishiMitra 2.0</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#DCFCE7', 100: '#BBF7D0', 200: '#86EFAC', 300: '#4ADE80', 400: '#22C55E', 500: '#16A34A', 600: '#15803D', 700: '#166534', 800: '#14532D', 900: '#052E16' },
                        accent: { 50: '#FEF9C3', 100: '#FEF08A', 200: '#FDE047', 300: '#FACC15', 400: '#EAB308', 500: '#CA8A04' }
                    },
                    fontFamily: { inter: ['Inter', 'sans-serif'], poppins: ['Poppins', 'sans-serif'] }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-poppins { font-family: 'Poppins', sans-serif; }
        .sidebar { transition: all 0.3s ease; }
        .sidebar-item:hover { background: linear-gradient(90deg, rgba(22, 101, 52, 0.1) 0%, transparent 100%); }
        .sidebar-item.active { background: linear-gradient(90deg, #166534 0%, #22C55E 100%); color: white; }
    </style>
</head>
<body class="font-inter bg-gray-50">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="sidebar w-64 bg-white shadow-xl fixed h-full z-40">
            <div class="p-6 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <span class="text-4xl">🌾</span>
                    <span class="font-poppins font-bold text-xl text-primary-700">KrishiMitra</span>
                </div>
            </div>
            <nav class="p-4 space-y-2">
                <a href="/dashboard" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                    Dashboard
                </a>
                <a href="/analysis" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Crop Analysis
                </a>
                <a href="/weather" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
                    Weather
                </a>
                <a href="/market" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    Market Prices
                </a>
                <a href="/history" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    History
                </a>
                <a href="/profile" class="sidebar-item active flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Profile
                </a>
            </nav>
            <div class="absolute bottom-0 left-0 right-0 p-4">
                <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-600 font-medium hover:bg-red-50 transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="ml-64 flex-1 p-8">
            <header class="mb-8">
                <h1 class="font-poppins font-bold text-3xl text-gray-800">Profile Settings</h1>
                <p class="text-gray-500 mt-1">Manage your account settings and preferences</p>
            </header>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Profile Card -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl p-8 shadow-lg">
                        <div class="text-center">
                            <div class="relative inline-block">
                                <div class="w-32 h-32 bg-gradient-to-br from-primary-400 to-primary-600 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <span class="text-5xl text-white">👨‍🌾</span>
                                </div>
                                <button class="absolute bottom-4 right-0 w-10 h-10 bg-primary-600 rounded-full flex items-center justify-center text-white shadow-lg hover:bg-primary-700 transition">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                </button>
                            </div>
                            <h2 class="font-poppins font-bold text-xl text-gray-800">Ramesh Patil</h2>
                            <p class="text-gray-500">Farmer</p>
                            <div class="mt-4 flex justify-center gap-2">
                                <span class="px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-sm">Verified</span>
                                <span class="px-3 py-1 bg-accent-100 text-accent-700 rounded-full text-sm">Premium</span>
                            </div>
                        </div>
                        
                        <div class="mt-8 space-y-4">
                            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl">
                                <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
                                    <span class="text-xl">📧</span>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-500">Email</p>
                                    <p class="font-medium">ramesh@email.com</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl">
                                <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
                                    <span class="text-xl">📱</span>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-500">Phone</p>
                                    <p class="font-medium">+91 98765 43210</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl">
                                <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
                                    <span class="text-xl">📍</span>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-500">Location</p>
                                    <p class="font-medium">Sangli, Maharashtra</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl">
                                <div class="w-10 h-10 bg-primary-100 rounded-full flex items-center justify-center">
                                    <span class="text-xl">🏪</span>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-500">Primary Mandi</p>
                                    <p class="font-medium">Sangli APMC</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Settings -->
                <div class="lg:col-span-2 space-y-8">
                    <!-- Language & Theme -->
                    <div class="bg-white rounded-2xl p-8 shadow-lg">
                        <h3 class="font-poppins font-bold text-xl text-gray-800 mb-6">Preferences</h3>
                        
                        <div class="space-y-6">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-medium text-gray-800">Language</p>
                                    <p class="text-sm text-gray-500">Select your preferred language</p>
                                </div>
                                <select id="languageSelect" class="px-4 py-2 border-2 border-gray-200 rounded-xl focus:border-primary-500 outline-none" onchange="changeLanguage(this.value)">
                                    <option value="en">English</option>
                                    <option value="hi">हिंदी (Hindi)</option>
                                    <option value="mr">मराठी (Marathi)</option>
                                </select>
                            </div>
                            
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-medium text-gray-800">Dark Mode</p>
                                    <p class="text-sm text-gray-500">Toggle dark theme</p>
                                </div>
                                <button id="darkModeToggle" onclick="toggleDarkMode()" class="relative w-14 h-8 bg-gray-200 rounded-full transition-colors">
                                    <span class="absolute left-1 top-1 w-6 h-6 bg-white rounded-full shadow transition-transform"></span>
                                </button>
                            </div>
                            
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-medium text-gray-800">Notifications</p>
                                    <p class="text-sm text-gray-500">Receive weather and price alerts</p>
                                </div>
                                <button class="relative w-14 h-8 bg-primary-600 rounded-full transition-colors">
                                    <span class="absolute right-1 top-1 w-6 h-6 bg-white rounded-full shadow transition-transform"></span>
                                </button>
                            </div>
                            
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-medium text-gray-800">Voice Assistant</p>
                                    <p class="text-sm text-gray-500">Enable text-to-speech</p>
                                </div>
                                <button class="relative w-14 h-8 bg-primary-600 rounded-full transition-colors">
                                    <span class="absolute right-1 top-1 w-6 h-6 bg-white rounded-full shadow transition-transform"></span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Change Password -->
                    <div class="bg-white rounded-2xl p-8 shadow-lg">
                        <h3 class="font-poppins font-bold text-xl text-gray-800 mb-6">Change Password</h3>
                        
                        <form class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Current Password</label>
                                <input type="password" class="w-full px-5 py-3 border-2 border-gray-200 rounded-xl focus:border-primary-500 focus:outline-none" placeholder="Enter current password">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">New Password</label>
                                <input type="password" class="w-full px-5 py-3 border-2 border-gray-200 rounded-xl focus:border-primary-500 focus:outline-none" placeholder="Enter new password">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Confirm New Password</label>
                                <input type="password" class="w-full px-5 py-3 border-2 border-gray-200 rounded-xl focus:border-primary-500 focus:outline-none" placeholder="Confirm new password">
                            </div>
                            <button type="submit" class="w-full py-3 px-6 bg-primary-600 text-white font-bold rounded-xl hover:bg-primary-700 transition-all">
                                Update Password
                            </button>
                        </form>
                    </div>

                    <!-- Danger Zone -->
                    <div class="bg-white rounded-2xl p-8 shadow-lg border-2 border-red-100">
                        <h3 class="font-poppins font-bold text-xl text-red-600 mb-6">Danger Zone</h3>
                        <p class="text-gray-500 mb-4">Once you delete your account, there is no going back. Please be certain.</p>
                        <button class="px-6 py-3 border-2 border-red-600 text-red-600 font-bold rounded-xl hover:bg-red-50 transition-all">
                            Delete Account
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        function changeLanguage(lang) {
            localStorage.setItem('language', lang);
            alert('Language changed to ' + (lang === 'en' ? 'English' : lang === 'hi' ? 'हिंदी' : 'मराठी'));
        }

        function toggleDarkMode() {
            const toggle = document.getElementById('darkModeToggle');
            toggle.classList.toggle('bg-primary-600');
            toggle.classList.toggle('bg-gray-200');
            document.documentElement.classList.toggle('dark');
        }
    </script>
</body>
</html>

