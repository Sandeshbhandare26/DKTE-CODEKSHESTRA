<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>History - KrishiMitra 2.0</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#DCFCE7', 100: '#BBF7D0', 200: '#86EFAC', 300: '#4ADE80', 400: '#22C55E', 500: '#16A34A', 600: '#15803D', 700: '#166534', 800: '#14532D', 900: '#052E16' },
                        accent: { 50: '#FEF9C3', 100: '#FEF08A', 200: '#FDE047', 300: '#FACC15', 400: '#EAB308', 500: '#CA8A04' }
                    },
                    fontFamily: { inter: ['Inter', 'sans-serif'], poppins: ['Poppins', 'sans-serif'] }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-poppins { font-family: 'Poppins', sans-serif; }
        .sidebar { transition: all 0.3s ease; }
        .sidebar-item:hover { background: linear-gradient(90deg, rgba(22, 101, 52, 0.1) 0%, transparent 100%); }
        .sidebar-item.active { background: linear-gradient(90deg, #166534 0%, #22C55E 100%); color: white; }
    </style>
</head>
<body class="font-inter bg-gray-50">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="sidebar w-64 bg-white shadow-xl fixed h-full z-40">
            <div class="p-6 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <span class="text-4xl">🌾</span>
                    <span class="font-poppins font-bold text-xl text-primary-700">KrishiMitra</span>
                </div>
            </div>
            <nav class="p-4 space-y-2">
                <a href="/dashboard" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                    Dashboard
                </a>
                <a href="/analysis" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Crop Analysis
                </a>
                <a href="/weather" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
                    Weather
                </a>
                <a href="/market" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    Market Prices
                </a>
                <a href="/history" class="sidebar-item active flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    History
                </a>
                <a href="/profile" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Profile
                </a>
            </nav>
            <div class="absolute bottom-0 left-0 right-0 p-4">
                <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-600 font-medium hover:bg-red-50 transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="ml-64 flex-1 p-8">
            <header class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="font-poppins font-bold text-3xl text-gray-800">Prediction History</h1>
                    <p class="text-gray-500 mt-1">View all your crop disease and price predictions</p>
                </div>
            </header>

            <!-- Search and Filters -->
            <div class="bg-white rounded-2xl p-6 shadow-lg mb-8">
                <div class="flex flex-wrap gap-4 items-center">
                    <div class="flex-1 min-w-64">
                        <div class="relative">
                            <input type="text" id="searchInput" placeholder="Search predictions..." class="w-full px-5 py-3 pl-12 border-2 border-gray-200 rounded-xl focus:border-primary-500 focus:outline-none">
                            <svg class="w-6 h-6 absolute left-4 top-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                        </div>
                    </div>
                    <select class="px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-primary-500 outline-none">
                        <option>All Types</option>
                        <option>Disease Detection</option>
                        <option>Price Prediction</option>
                    </select>
                    <select class="px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-primary-500 outline-none">
                        <option>All Crops</option>
                        <option>Tomato</option>
                        <option>Potato</option>
                        <option>Onion</option>
                        <option>Cabbage</option>
                    </select>
                    <select class="px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-primary-500 outline-none">
                        <option>Last 30 Days</option>
                        <option>Last 7 Days</option>
                        <option>Last 90 Days</option>
                        <option>All Time</option>
                    </select>
                </div>
            </div>

            <!-- History Table -->
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
                <table class="w-full">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="text-left py-4 px-6 font-semibold text-gray-600">Date</th>
                            <th class="text-left py-4 px-6 font-semibold text-gray-600">Type</th>
                            <th class="text-left py-4 px-6 font-semibold text-gray-600">Crop</th>
                            <th class="text-left py-4 px-6 font-semibold text-gray-600">Analysis</th>
                            <th class="text-left py-4 px-6 font-semibold text-gray-600">Confidence</th>
                            <th class="text-left py-4 px-6 font-semibold text-gray-600">Action</th>
                        </tr>
                    </thead>
                    <tbody id="historyTable">
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                            <td class="py-4 px-6 text-gray-600">Mar 6, 2026</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm">Disease</span></td>
                            <td class="py-4 px-6">🍅 Tomato</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">Healthy</span></td>
                            <td class="py-4 px-6 font-semibold text-primary-600">98%</td>
                            <td class="py-4 px-6">
                                <button onclick="viewDetails(1)" class="text-primary-600 hover:underline mr-3">View</button>
                                <button onclick="deletePrediction(1)" class="text-red-600 hover:underline">Delete</button>
                            </td>
                        </tr>
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                            <td class="py-4 px-6 text-gray-600">Mar 5, 2026</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm">Disease</span></td>
                            <td class="py-4 px-6">🥔 Potato</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-sm">Early Blight</span></td>
                            <td class="py-4 px-6 font-semibold text-primary-600">95%</td>
                            <td class="py-4 px-6">
                                <button onclick="viewDetails(2)" class="text-primary-600 hover:underline mr-3">View</button>
                                <button onclick="deletePrediction(2)" class="text-red-600 hover:underline">Delete</button>
                            </td>
                        </tr>
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                            <td class="py-4 px-6 text-gray-600">Mar 4, 2026</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm">Price</span></td>
                            <td class="py-4 px-6">🧅 Onion</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">₹2,890</span></td>
                            <td class="py-4 px-6 font-semibold text-primary-600">92%</td>
                            <td class="py-4 px-6">
                                <button onclick="viewDetails(3)" class="text-primary-600 hover:underline mr-3">View</button>
                                <button onclick="deletePrediction(3)" class="text-red-600 hover:underline">Delete</button>
                            </td>
                        </tr>
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                            <td class="py-4 px-6 text-gray-600">Mar 3, 2026</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm">Disease</span></td>
                            <td class="py-4 px-6">🌶️ Chili</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">Healthy</span></td>
                            <td class="py-4 px-6 font-semibold text-primary-600">97%</td>
                            <td class="py-4 px-6">
                                <button onclick="viewDetails(4)" class="text-primary-600 hover:underline mr-3">View</button>
                                <button onclick="deletePrediction(4)" class="text-red-600 hover:underline">Delete</button>
                            </td>
                        </tr>
                        <tr class="hover:bg-gray-50">
                            <td class="py-4 px-6 text-gray-600">Mar 2, 2026</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm">Price</span></td>
                            <td class="py-4 px-6">🍅 Tomato</td>
                            <td class="py-4 px-6"><span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">₹1,240</span></td>
                            <td class="py-4 px-6 font-semibold text-primary-600">89%</td>
                            <td class="py-4 px-6">
                                <button onclick="viewDetails(5)" class="text-primary-600 hover:underline mr-3">View</button>
                                <button onclick="deletePrediction(5)" class="text-red-600 hover:underline">Delete</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="flex justify-center mt-6 gap-2">
                <button class="px-4 py-2 border-2 border-gray-200 rounded-xl hover:border-primary-500 transition">Previous</button>
                <button class="px-4 py-2 bg-primary-600 text-white rounded-xl">1</button>
                <button class="px-4 py-2 border-2 border-gray-200 rounded-xl hover:border-primary-500 transition">2</button>
                <button class="px-4 py-2 border-2 border-gray-200 rounded-xl hover:border-primary-500 transition">3</button>
                <button class="px-4 py-2 border-2 border-gray-200 rounded-xl hover:border-primary-500 transition">Next</button>
            </div>
        </main>
    </div>

    <!-- View Details Modal -->
    <div id="viewModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-8 max-w-lg w-full mx-4">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-poppins font-bold text-xl">Prediction Details</h3>
                <button onclick="closeModal()" class="text-gray-500 hover:text-gray-700">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div id="modalContent" class="space-y-4">
                <!-- Content will be populated dynamically -->
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-8 max-w-sm w-full mx-4">
            <div class="text-center">
                <span class="text-6xl">🗑️</span>
                <h3 class="font-poppins font-bold text-xl mt-4">Delete Prediction?</h3>
                <p class="text-gray-500 mt-2">This action cannot be undone.</p>
            </div>
            <div class="flex gap-4 mt-6">
                <button onclick="closeDeleteModal()" class="flex-1 px-4 py-3 border-2 border-gray-200 rounded-xl hover:border-primary-500 transition">Cancel</button>
                <button onclick="confirmDelete()" class="flex-1 px-4 py-3 bg-red-600 text-white rounded-xl hover:bg-red-700 transition">Delete</button>
            </div>
        </div>
    </div>

    <script>
        let deleteId = null;

        function viewDetails(id) {
            const modal = document.getElementById('viewModal');
            const content = document.getElementById('modalContent');
            
            content.innerHTML = `
                <div class="flex justify-between p-4 bg-gray-50 rounded-xl">
                    <span class="text-gray-600">Date</span>
                    <span class="font-semibold">Mar 6, 2026</span>
                </div>
                <div class="flex justify-between p-4 bg-gray-50 rounded-xl">
                    <span class="text-gray-600">Type</span>
                    <span class="font-semibold">Disease Detection</span>
                </div>
                <div class="flex justify-between p-4 bg-gray-50 rounded-xl">
                    <span class="text-gray-600">Crop</span>
                    <span class="font-semibold">Tomato</span>
                </div>
                <div class="flex justify-between p-4 bg-gray-50 rounded-xl">
                    <span class="text-gray-600">Result</span>
                    <span class="font-semibold text-green-600">Healthy</span>
                </div>
                <div class="flex justify-between p-4 bg-gray-50 rounded-xl">
                    <span class="text-gray-600">Confidence</span>
                    <span class="font-semibold text-primary-600">98%</span>
                </div>
                <div class="p-4 bg-primary-50 rounded-xl border border-primary-200 mt-4">
                    <h4 class="font-semibold text-primary-800 mb-2">Recommendation</h4>
                    <p class="text-primary-700 text-sm">Continue with regular farming practices. Your crop is healthy!</p>
                </div>
            `;
            
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeModal() {
            const modal = document.getElementById('viewModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function deletePrediction(id) {
            deleteId = id;
            const modal = document.getElementById('deleteModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeDeleteModal() {
            const modal = document.getElementById('deleteModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            deleteId = null;
        }

        function confirmDelete() {
            if (deleteId) {
                alert('Prediction deleted successfully!');
                closeDeleteModal();
            }
        }

        // Search functionality
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#historyTable tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });
    </script>
</body>
</html>

