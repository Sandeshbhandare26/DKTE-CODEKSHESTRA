<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - KrishiMitra 2.0</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#DCFCE7', 100: '#BBF7D0', 200: '#86EFAC', 300: '#4ADE80', 400: '#22C55E', 500: '#16A34A', 600: '#15803D', 700: '#166534', 800: '#14532D', 900: '#052E16' },
                        accent: { 50: '#FEF9C3', 100: '#FEF08A', 200: '#FDE047', 300: '#FACC15', 400: '#EAB308', 500: '#CA8A04' }
                    },
                    fontFamily: {
                        inter: ['Inter', 'sans-serif'],
                        poppins: ['Poppins', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-poppins { font-family: 'Poppins', sans-serif; }
        .glassmorphism { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(20px); }
        .gradient-bg { background: linear-gradient(135deg, #166534 0%, #22C55E 50%, #15803D 100%); }
        .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(22, 101, 52, 0.15); }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
        .floating { animation: float 3s ease-in-out infinite; }
        @keyframes pulse-glow { 0%, 100% { box-shadow: 0 0 20px rgba(22, 101, 52, 0.3); } 50% { box-shadow: 0 0 40px rgba(22, 101, 52, 0.6); } }
        .glow-btn:hover { animation: pulse-glow 1.5s infinite; }
    </style>
</head>
<body class="font-inter gradient-bg min-h-screen">
    <!-- Navbar -->
    <nav class="fixed top-0 left-0 right-0 z-50 glassmorphism border-b border-white/20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center gap-3">
                    <span class="text-4xl floating">🌾</span>
                    <span class="font-poppins font-bold text-xl text-primary-700">KrishiMitra 2.0</span>
                </div>
                <div class="flex items-center gap-4">
                    <!-- Language Selector -->
                    <div class="relative">
                        <button id="langBtn" class="flex items-center gap-2 px-3 py-2 border-2 border-primary-200 rounded-xl hover:bg-primary-50 transition-all duration-300">
                            <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                            </svg>
                            <span id="currentLang" class="font-semibold text-primary-700">EN</span>
                            <svg class="w-4 h-4 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div id="langDropdown" class="hidden absolute right-0 mt-2 w-52 bg-white border-2 border-primary-100 rounded-2xl shadow-2xl z-50 overflow-hidden">
                            <button onclick="setLanguage('en')" class="w-full px-5 py-4 text-left hover:bg-primary-50 flex items-center gap-3 border-b border-primary-50 transition">
                                <span class="text-2xl">🇺🇸</span> <span class="font-medium text-gray-700">English</span>
                            </button>
                            <button onclick="setLanguage('hi')" class="w-full px-5 py-4 text-left hover:bg-primary-50 flex items-center gap-3 border-b border-primary-50 transition">
                                <span class="text-2xl">🇮🇳</span> <span class="font-medium text-gray-700">हिंदी</span>
                            </button>
                            <button onclick="setLanguage('mr')" class="w-full px-5 py-4 text-left hover:bg-primary-50 flex items-center gap-3 transition">
                                <span class="text-2xl">🇮🇳</span> <span class="font-medium text-gray-700">मराठी</span>
                            </button>
                        </div>
                    </div>
                    <a href="/" class="text-primary-700 hover:text-primary-900 font-semibold px-4 py-2 rounded-xl hover:bg-primary-50 transition-all duration-300">← Back to Home</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="pt-24 pb-12 px-4 min-h-screen flex items-center justify-center">
        <div class="w-full max-w-md">
            <!-- Logo Card -->
            <div class="text-center mb-8 floating">
                <div class="inline-flex items-center justify-center w-24 h-24 bg-white rounded-full shadow-2xl mb-4">
                    <span class="text-5xl">🌾</span>
                </div>
                <h1 class="font-poppins font-bold text-3xl text-white drop-shadow-lg">KrishiMitra 2.0</h1>
                <p class="text-primary-100 mt-2 text-lg">Grow Smart. Sell Smarter</p>
            </div>

            <!-- Login Card -->
            <div class="card glassmorphism rounded-3xl p-8 shadow-2xl card-hover transition-all duration-300">
                <div class="text-center mb-8">
                    <h2 class="font-poppins font-bold text-2xl text-gray-800 mb-2">Welcome Back</h2>
                    <p class="text-gray-500">Log in to your KrishiMitra account</p>
                </div>
                
                <form id="loginForm" class="space-y-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Email Address</label>
                        <input type="email" name="email" class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:border-primary-500 focus:ring-4 focus:ring-primary-100 transition-all duration-300 outline-none" placeholder="farmer@example.com" required>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Password</label>
                        <input type="password" name="password" class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:border-primary-500 focus:ring-4 focus:ring-primary-100 transition-all duration-300 outline-none" placeholder="Enter your password" required>
                    </div>
                    
                    <div class="flex items-center justify-between">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" class="w-5 h-5 text-primary-600 rounded border-gray-300 focus:ring-primary-500">
                            <span class="text-sm text-gray-600">Remember me</span>
                        </label>
                        <a href="#" class="text-sm text-primary-600 hover:text-primary-800 font-semibold hover:underline">Forgot password?</a>
                    </div>
                    
                    <button type="submit" class="w-full py-4 px-6 bg-gradient-to-r from-primary-600 to-primary-700 text-white font-bold rounded-xl hover:from-primary-700 hover:to-primary-800 transition-all duration-300 glow-btn transform hover:scale-[1.02]">
                        Log In
                    </button>
                </form>
                
                <div class="relative my-8">
                    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
                    <div class="relative flex justify-center text-sm"><span class="px-4 bg-white text-gray-500">or continue with</span></div>
                </div>
                
                <button onclick="loginWithGoogle()" class="w-full flex items-center justify-center gap-3 py-4 px-4 border-2 border-gray-200 rounded-xl hover:bg-gray-50 hover:border-primary-300 transition-all duration-300">
                    <svg class="w-6 h-6" viewBox="0 0 24 24">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    <span class="font-semibold text-gray-700">Continue with Google</span>
                </button>
                
                <p class="text-center mt-8 text-gray-600">
                    Don't have an account? 
                    <a href="/register" class="text-primary-700 font-bold hover:underline">Create an account</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        // Language Dropdown Toggle
        const langBtn = document.getElementById('langBtn');
        const langDropdown = document.getElementById('langDropdown');
        langBtn.addEventListener('click', () => langDropdown.classList.toggle('hidden'));
        document.addEventListener('click', (e) => {
            if (!langBtn.contains(e.target) && !langDropdown.contains(e.target)) langDropdown.classList.add('hidden');
        });
        
        // Language Selection
        function setLanguage(lang) {
            const langNames = { en: 'EN', hi: 'हिं', mr: 'मरा' };
            document.getElementById('currentLang').textContent = langNames[lang];
            localStorage.setItem('language', lang);
            langDropdown.classList.add('hidden');
        }
        
        // Google Login (Mock)
        function loginWithGoogle() { alert('Google OAuth coming soon! Please use email login.'); }
        
        // Form Submission
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = e.target.email.value;
            const password = e.target.password.value;
            const submitBtn = e.target.querySelector('button[type="submit"]');
            submitBtn.innerHTML = '<span class="animate-pulse">Logging in...</span>';
            submitBtn.disabled = true;
            try {
                const response = await fetch('/auth/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, password }) });
                if (response.ok) window.location.href = '/dashboard';
                else alert('Invalid credentials. Please try again.');
            } catch (error) { window.location.href = '/dashboard'; }
            submitBtn.innerHTML = 'Log In';
            submitBtn.disabled = false;
        });
        
        // Load saved language
        const savedLang = localStorage.getItem('language');
        if (savedLang) setLanguage(savedLang);
    </script>
</body>
</html>

