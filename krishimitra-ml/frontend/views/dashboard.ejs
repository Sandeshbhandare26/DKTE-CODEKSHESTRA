<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - KrishiMitra 2.0</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#DCFCE7', 100: '#BBF7D0', 200: '#86EFAC', 300: '#4ADE80', 400: '#22C55E', 500: '#16A34A', 600: '#15803D', 700: '#166534', 800: '#14532D', 900: '#052E16' },
                        accent: { 50: '#FEF9C3', 100: '#FEF08A', 200: '#FDE047', 300: '#FACC15', 400: '#EAB308', 500: '#CA8A04' }
                    },
                    fontFamily: { inter: ['Inter', 'sans-serif'], poppins: ['Poppins', 'sans-serif'] }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-poppins { font-family: 'Poppins', sans-serif; }
        .sidebar { transition: all 0.3s ease; }
        .sidebar-item:hover { background: linear-gradient(90deg, rgba(22, 101, 52, 0.1) 0%, transparent 100%); }
        .sidebar-item.active { background: linear-gradient(90deg, #166534 0%, #22C55E 100%); color: white; }
        .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(22, 101, 52, 0.15); }
        @keyframes slideIn { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
        .animate-slide { animation: slideIn 0.5s ease-out; }
    </style>
</head>
<body class="font-inter bg-gray-50">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="sidebar w-64 bg-white shadow-xl fixed h-full z-40">
            <div class="p-6 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <span class="text-4xl">🌾</span>
                    <span class="font-poppins font-bold text-xl text-primary-700">KrishiMitra</span>
                </div>
            </div>
            
            <nav class="p-4 space-y-2">
                <a href="/dashboard" class="sidebar-item active flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                    </svg>
                    Dashboard
                </a>
                <a href="/analysis" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    Crop Analysis
                </a>
                <a href="/weather" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                    </svg>
                    Weather
                </a>
                <a href="/market" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    Market Prices
                </a>
                <a href="/history" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    History
                </a>
                <a href="/profile" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Profile
                </a>
            </nav>
            
            <div class="absolute bottom-0 left-0 right-0 p-4">
                <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-600 font-medium hover:bg-red-50 transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="ml-64 flex-1 p-8">
            <!-- Header -->
            <header class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="font-poppins font-bold text-3xl text-gray-800">Welcome back, Farmer! 👨‍🌾</h1>
                    <p class="text-gray-500 mt-1">Here's what's happening with your farm today</p>
                </div>
                <div class="flex items-center gap-4">
                    <!-- Language Selector -->
                    <div class="relative">
                        <button id="langBtn" class="flex items-center gap-2 px-4 py-2 bg-white border-2 border-gray-200 rounded-xl hover:border-primary-500 transition">
                            <span id="currentLang">EN</span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div id="langDropdown" class="hidden absolute right-0 mt-2 w-40 bg-white border-2 border-gray-100 rounded-xl shadow-lg z-50">
                            <button onclick="setLanguage('en')" class="w-full px-4 py-2 text-left hover:bg-gray-50">English</button>
                            <button onclick="setLanguage('hi')" class="w-full px-4 py-2 text-left hover:bg-gray-50">हिंदी</button>
                            <button onclick="setLanguage('mr')" class="w-full px-4 py-2 text-left hover:bg-gray-50">मराठी</button>
                        </div>
                    </div>
                    <!-- Dark Mode Toggle -->
                    <button onclick="toggleDarkMode()" class="p-2 bg-white border-2 border-gray-200 rounded-xl hover:border-primary-500 transition">
                        <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                    </button>
                </div>
            </header>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white rounded-2xl p-6 shadow-lg card-hover transition-all duration-300">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-sm font-medium">Crop Health Score</p>
                            <p class="text-3xl font-bold text-primary-600 mt-1">92%</p>
                        </div>
                        <div class="w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center">
                            <span class="text-3xl">🌿</span>
                        </div>
                    </div>
                    <p class="text-green-500 text-sm mt-3">↑ 5% from last week</p>
                </div>
                
                <div class="bg-white rounded-2xl p-6 shadow-lg card-hover transition-all duration-300">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-sm font-medium">Estimated Yield</p>
                            <p class="text-3xl font-bold text-primary-600 mt-1">2,450 kg</p>
                        </div>
                        <div class="w-14 h-14 bg-accent-100 rounded-full flex items-center justify-center">
                            <span class="text-3xl">🌾</span>
                        </div>
                    </div>
                    <p class="text-green-500 text-sm mt-3">↑ 12% from last season</p>
                </div>
                
                <div class="bg-white rounded-2xl p-6 shadow-lg card-hover transition-all duration-300">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-sm font-medium">Irrigation Savings</p>
                            <p class="text-3xl font-bold text-primary-600 mt-1">₹8,500</p>
                        </div>
                        <div class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center">
                            <span class="text-3xl">💧</span>
                        </div>
                    </div>
                    <p class="text-green-500 text-sm mt-3">↑ 18% water saved</p>
                </div>
                
                <div class="bg-white rounded-2xl p-6 shadow-lg card-hover transition-all duration-300">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-gray-500 text-sm font-medium">Predicted Profit</p>
                            <p class="text-3xl font-bold text-primary-600 mt-1">₹48,300</p>
                        </div>
                        <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center">
                            <span class="text-3xl">📈</span>
                        </div>
                    </div>
                    <p class="text-green-500 text-sm mt-3">↑ 23% from last year</p>
                </div>
            </div>

            <!-- Charts Section -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                <!-- Weather Widget -->
                <div class="bg-white rounded-2xl p-6 shadow-lg">
                    <h3 class="font-poppins font-bold text-xl text-gray-800 mb-4">Weather Forecast</h3>
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center gap-4">
                            <span class="text-6xl">☀️</span>
                            <div>
                                <p class="text-4xl font-bold text-gray-800">28°C</p>
                                <p class="text-gray-500">Sunny Day</p>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-4 gap-4 text-center">
                        <div class="p-3 bg-gray-50 rounded-xl"><p class="text-sm text-gray-500">Mon</p><p class="text-2xl">☀️</p><p class="font-semibold">28°C</p></div>
                        <div class="p-3 bg-gray-50 rounded-xl"><p class="text-sm text-gray-500">Tue</p><p class="text-2xl">⛅</p><p class="font-semibold">26°C</p></div>
                        <div class="p-3 bg-gray-50 rounded-xl"><p class="text-sm text-gray-500">Wed</p><p class="text-2xl">🌧️</p><p class="font-semibold">24°C</p></div>
                        <div class="p-3 bg-gray-50 rounded-xl"><p class="text-sm text-gray-500">Thu</p><p class="text-2xl">☀️</p><p class="font-semibold">27°C</p></div>
                    </div>
                </div>
                
                <!-- Price Trend Chart -->
                <div class="bg-white rounded-2xl p-6 shadow-lg">
                    <h3 class="font-poppins font-bold text-xl text-gray-800 mb-4">Market Price Trends</h3>
                    <canvas id="priceChart" height="200"></canvas>
                </div>
            </div>

            <!-- Recent Activity Table -->
            <div class="bg-white rounded-2xl p-6 shadow-lg">
                <h3 class="font-poppins font-bold text-xl text-gray-800 mb-4">Recent Predictions</h3>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-gray-200">
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Date</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Crop</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Analysis</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Confidence</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-3 px-4">Today</td>
                                <td class="py-3 px-4">🍅 Tomato</td>
                                <td class="py-3 px-4"><span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">Healthy</span></td>
                                <td class="py-3 px-4">98%</td>
                                <td class="py-3 px-4"><button class="text-primary-600 hover:underline">View</button></td>
                            </tr>
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-3 px-4">Yesterday</td>
                                <td class="py-3 px-4">🥔 Potato</td>
                                <td class="py-3 px-4"><span class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-sm">Early Blight</span></td>
                                <td class="py-3 px-4">95%</td>
                                <td class="py-3 px-4"><button class="text-primary-600 hover:underline">View</button></td>
                            </tr>
                            <tr class="hover:bg-gray-50">
                                <td class="py-3 px-4">2 days ago</td>
                                <td class="py-3 px-4">🧅 Onion</td>
                                <td class="py-3 px-4"><span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">Healthy</span></td>
                                <td class="py-3 px-4">97%</td>
                                <td class="py-3 px-4"><button class="text-primary-600 hover:underline">View</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Chart
        const ctx = document.getElementById('priceChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                datasets: [{
                    label: 'Tomato Price (₹)',
                    data: [1200, 1350, 1280, 1420, 1380, 1450],
                    borderColor: '#166534',
                    backgroundColor: 'rgba(22, 101, 52, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: { responsive: true, plugins: { legend: { display: true } } }
        });

        // Language Toggle
        const langBtn = document.getElementById('langBtn');
        const langDropdown = document.getElementById('langDropdown');
        langBtn.addEventListener('click', () => langDropdown.classList.toggle('hidden'));
        document.addEventListener('click', (e) => {
            if (!langBtn.contains(e.target) && !langDropdown.contains(e.target)) langDropdown.classList.add('hidden');
        });
        function setLanguage(lang) {
            document.getElementById('currentLang').textContent = lang.toUpperCase();
            localStorage.setItem('language', lang);
            langDropdown.classList.add('hidden');
        }
        
        // Dark Mode Toggle
        function toggleDarkMode() {
            document.documentElement.classList.toggle('dark');
        }
    </script>
</body>
</html>
