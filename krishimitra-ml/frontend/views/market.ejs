<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Market Prices - KrishiMitra 2.0</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#DCFCE7', 100: '#BBF7D0', 200: '#86EFAC', 300: '#4ADE80', 400: '#22C55E', 500: '#16A34A', 600: '#15803D', 700: '#166534', 800: '#14532D', 900: '#052E16' },
                        accent: { 50: '#FEF9C3', 100: '#FEF08A', 200: '#FDE047', 300: '#FACC15', 400: '#EAB308', 500: '#CA8A04' }
                    },
                    fontFamily: { inter: ['Inter', 'sans-serif'], poppins: ['Poppins', 'sans-serif'] }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-poppins { font-family: 'Poppins', sans-serif; }
        .sidebar { transition: all 0.3s ease; }
        .sidebar-item:hover { background: linear-gradient(90deg, rgba(22, 101, 52, 0.1) 0%, transparent 100%); }
        .sidebar-item.active { background: linear-gradient(90deg, #166534 0%, #22C55E 100%); color: white; }
        .price-up { animation: pulse-green 2s infinite; }
        .price-down { animation: pulse-red 2s infinite; }
        @keyframes pulse-green { 0%, 100% { background-color: #DCFCE7; } 50% { background-color: #BBF7D0; } }
        @keyframes pulse-red { 0%, 100% { background-color: #FEE2E2; } 50% { background-color: #FECACA; } }
    </style>
</head>
<body class="font-inter bg-gray-50">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="sidebar w-64 bg-white shadow-xl fixed h-full z-40">
            <div class="p-6 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <span class="text-4xl">🌾</span>
                    <span class="font-poppins font-bold text-xl text-primary-700">KrishiMitra</span>
                </div>
            </div>
            <nav class="p-4 space-y-2">
                <a href="/dashboard" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                    Dashboard
                </a>
                <a href="/analysis" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Crop Analysis
                </a>
                <a href="/weather" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
                    Weather
                </a>
                <a href="/market" class="sidebar-item active flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    Market Prices
                </a>
                <a href="/history" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    History
                </a>
                <a href="/profile" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Profile
                </a>
            </nav>
            <div class="absolute bottom-0 left-0 right-0 p-4">
                <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-600 font-medium hover:bg-red-50 transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="ml-64 flex-1 p-8">
            <header class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="font-poppins font-bold text-3xl text-gray-800">Mandi Price Prediction</h1>
                    <p class="text-gray-500 mt-1">Real-time market prices and AI-powered price predictions</p>
                </div>
                <select id="marketSelect" onchange="loadMarketData()" class="px-4 py-2 border-2 border-gray-200 rounded-xl focus:border-primary-500 outline-none bg-white">
                    <option value="all">All Markets</option>
                    <option value="Sangli APMC Market Yard">Sangli APMC</option>
                    <option value="Miraj Vegetable Market">Miraj Vegetable Market</option>
                    <option value="Atpadi Wholesale Market">Atpadi Wholesale Market</option>
                    <option value="Bhivghat Vegetable Market">Bhivghat Vegetable Market</option>
                    <option value="Palus APMC Market">Palus APMC Market</option>
                </select>
            </header>

            <!-- Crop Price Cards -->
            <div id="cropCards" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-8">
                <!-- Loading state -->
                <div class="col-span-full text-center py-8">
                    <div class="animate-spin rounded-full h-12 w-12 border-4 border-primary-600 border-t-transparent mx-auto"></div>
                    <p class="text-gray-500 mt-4">Loading market data...</p>
                </div>
            </div>

            <!-- Price Chart -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                <div class="lg:col-span-2 bg-white rounded-2xl p-8 shadow-lg">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-poppins font-bold text-xl text-gray-800">Price Trend - <span id="selectedCrop">Tomato</span></h3>
                        <select id="cropSelect" onchange="updateChart()" class="px-4 py-2 border-2 border-gray-200 rounded-xl focus:border-primary-500 outline-none bg-white">
                            <option value="Tomato">Tomato</option>
                            <option value="Potato">Potato</option>
                            <option value="Onion Big">Onion</option>
                            <option value="Cabbage">Cabbage</option>
                            <option value="Carrot">Carrot</option>
                            <option value="Cauliflower">Cauliflower</option>
                            <option value="Cucumber">Cucumber</option>
                            <option value="Spinach">Spinach</option>
                            <option value="Okra">Okra</option>
                            <option value="Brinjal Big">Brinjal</option>
                        </select>
                    </div>
                    <canvas id="priceChart" height="150"></canvas>
                </div>

                <!-- AI Recommendation -->
                <div class="bg-white rounded-2xl p-8 shadow-lg">
                    <h3 class="font-poppins font-bold text-xl text-gray-800 mb-6">🤖 AI Recommendation</h3>
                    <div id="recommendationContent" class="space-y-4">
                        <div class="p-4 bg-gray-50 rounded-xl">
                            <div class="animate-pulse bg-gray-200 h-4 w-3/4 rounded mb-2"></div>
                            <div class="animate-pulse bg-gray-200 h-3 w-1/2 rounded"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Market Table -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
                <h3 class="font-poppins font-bold text-xl text-gray-800 mb-6">Top Markets in Maharashtra</h3>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-gray-200">
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Market</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Tomato (₹)</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Potato (₹)</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Onion (₹)</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Cabbage (₹)</th>
                                <th class="text-left py-3 px-4 font-semibold text-gray-600">Action</th>
                            </tr>
                        </thead>
                        <tbody id="marketTableBody">
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-3 px-4 font-medium">Loading...</td>
                                <td class="py-3 px-4">-</td>
                                <td class="py-3 px-4">-</td>
                                <td class="py-3 px-4">-</td>
                                <td class="py-3 px-4">-</td>
                                <td class="py-3 px-4">-</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Global data storage
        let marketData = {};
        let priceChart = null;
        
        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadMarketData();
        });

        // Load all market data from API
        async function loadMarketData() {
            const market = document.getElementById('marketSelect').value;
            const cropCardsDiv = document.getElementById('cropCards');
            
            try {
                // Fetch price predictions for different crops
                const crops = ['Tomato', 'Potato', 'Onion Big', 'Cabbage', 'Carrot', 'Cauliflower', 'Cucumber', 'Spinach', 'Okra', 'Brinjal Big'];
                const pricePromises = crops.map(crop => 
                    fetch(`/api/price/${encodeURIComponent(crop)}`)
                        .then(res => res.json())
                        .catch(() => null)
                );
                
                const prices = await Promise.all(pricePromises);
                
                // Build crop cards
                let cardsHTML = '';
                crops.forEach((crop, index) => {
                    const price = prices[index];
                    const currentPrice = price ? price.today_price : Math.floor(Math.random() * 2000 + 500);
                    const change = Math.floor(Math.random() * 20 - 5);
                    const changeClass = change >= 0 ? 'text-green-600' : 'text-red-600';
                    const changeIcon = change >= 0 ? '↑' : '↓';
                    
                    const cropEmoji = getCropEmoji(crop);
                    
                    cardsHTML += `
                        <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all cursor-pointer transform hover:scale-105" onclick="selectCrop('${crop}')">
                            <div class="flex items-center gap-3 mb-3">
                                <span class="text-3xl">${cropEmoji}</span>
                                <span class="font-semibold text-gray-800">${crop.replace(' Big', '').replace(' Big', '')}</span>
                            </div>
                            <p class="text-2xl font-bold text-primary-600">₹${currentPrice.toLocaleString()}</p>
                            <p class="text-sm ${changeClass}">${changeIcon} ${Math.abs(change)}% this week</p>
                        </div>
                    `;
                });
                
                cropCardsDiv.innerHTML = cardsHTML;
                
                // Store prices for chart
                marketData = {};
                crops.forEach((crop, index) => {
                    marketData[crop] = prices[index] || generateMockPriceData(crop);
                });
                
                // Update chart and table
                updateChart();
                updateMarketTable();
                updateRecommendation();
                
            } catch (error) {
                console.error('Error loading market data:', error);
                // Load with mock data on error
                loadMockData();
            }
        }

        function generateMockPriceData(crop) {
            const basePrice = {
                'Tomato': 1200, 'Potato': 890, 'Onion Big': 2800, 'Cabbage': 650,
                'Carrot': 1100, 'Cauliflower': 780, 'Cucumber': 450, 'Spinach': 320,
                'Okra': 680, 'Brinjal Big': 520
            }[crop] || 1000;
            
            const forecast = [];
            for (let i = 1; i <= 7; i++) {
                const variation = (Math.random() - 0.3) * 0.2;
                forecast.push({ day: i, price: Math.floor(basePrice * (1 + variation)) });
            }
            
            return {
                crop: crop,
                today_price: basePrice,
                forecast: forecast
            };
        }

        function loadMockData() {
            const crops = ['Tomato', 'Potato', 'Onion Big', 'Cabbage', 'Carrot', 'Cauliflower'];
            const emojis = {'Tomato': '🍅', 'Potato': '🥔', 'Onion Big': '🧅', 'Cabbage': '🥬', 'Carrot': '🥕', 'Cauliflower': '🥦'};
            
            let cardsHTML = '';
            crops.forEach(crop => {
                const price = generateMockPriceData(crop);
                const change = Math.floor(Math.random() * 20 - 5);
                cardsHTML += `
                    <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all cursor-pointer transform hover:scale-105" onclick="selectCrop('${crop}')">
                        <div class="flex items-center gap-3 mb-3">
                            <span class="text-3xl">${emojis[crop] || '🥬'}</span>
                            <span class="font-semibold text-gray-800">${crop.replace(' Big', '')}</span>
                        </div>
                        <p class="text-2xl font-bold text-primary-600">₹${price.today_price.toLocaleString()}</p>
                        <p class="text-sm ${change >= 0 ? 'text-green-600' : 'text-red-600'}">${change >= 0 ? '↑' : '↓'} ${Math.abs(change)}% this week</p>
                    </div>
                `;
            });
            
            document.getElementById('cropCards').innerHTML = cardsHTML;
            updateChart();
        }

        function getCropEmoji(crop) {
            const emojis = {
                'Tomato': '🍅', 'Potato': '🥔', 'Onion Big': '🧅', 'Onion Small': '🧅',
                'Cabbage': '🥬', 'Carrot': '🥕', 'Cauliflower': '🥦', 'Cucumber': '🥒',
                'Spinach': '🥬', 'Okra': '🫛', 'Brinjal Big': '🍆', 'Bottlegourd': '🥒',
                'Bitter gourd': '🥒', 'Pumpkin': '🎃', 'Radish': '🥗', 'Ridge gourd': '🥒',
                'Green chili': '🌶️', 'Ginger': '🫚', 'Garlic': '🧄', 'Coriander leaves': '🌿',
                'Fenugreek leaves': '🌿'
            };
            return emojis[crop] || '🥬';
        }

        function selectCrop(crop) {
            document.getElementById('cropSelect').value = crop;
            updateChart();
        }

        function updateChart() {
            const crop = document.getElementById('cropSelect').value;
            document.getElementById('selectedCrop').textContent = crop.replace(' Big', '');
            
            const ctx = document.getElementById('priceChart').getContext('2d');
            const data = marketData[crop] || generateMockPriceData(crop);
            
            const chartData = data.forecast.map(f => f.price);
            
            if (priceChart) {
                priceChart.data.datasets[0].data = chartData;
                priceChart.update();
            } else {
                priceChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['Day 1', 'Day 2', 'Day 3', 'Day 4', 'Day 5', 'Day 6', 'Day 7'],
                        datasets: [{
                            label: 'Price (₹)',
                            data: chartData,
                            borderColor: '#166534',
                            backgroundColor: 'rgba(22, 101, 52, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointBackgroundColor: '#166534',
                            pointRadius: 5,
                            pointHoverRadius: 7
                        }]
                    },
                    options: { 
                        responsive: true, 
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: false, grid: { color: 'rgba(0,0,0,0.05)' } },
                            x: { grid: { display: false } }
                        }
                    }
                });
            }
            
            updateRecommendation();
        }

        function updateRecommendation() {
            const crop = document.getElementById('cropSelect').value;
            const data = marketData[crop] || generateMockPriceData(crop);
            
            const currentPrice = data.today_price;
            const forecast = data.forecast;
            const lastDayPrice = forecast[forecast.length - 1].price;
            const priceChange = ((lastDayPrice - currentPrice) / currentPrice) * 100;
            
            const isRising = priceChange > 0;
            const markets = ['Sangli APMC', 'Miraj Market', 'Atpadi Market'];
            const bestMarket = markets[Math.floor(Math.random() * markets.length)];
            
            let recommendationHTML = '';
            
            if (isRising) {
                recommendationHTML = `
                    <div class="p-4 bg-green-50 border-l-4 border-green-500 rounded-r-xl">
                        <p class="font-semibold text-green-800">📈 Price Expected to Rise</p>
                        <p class="text-sm text-green-700 mt-1">Prices may increase by ${Math.abs(priceChange).toFixed(1)}% in next 7 days</p>
                    </div>
                    <div class="p-4 bg-blue-50 border-l-4 border-blue-500 rounded-r-xl">
                        <p class="font-semibold text-blue-800">🏪 Best Market: ${bestMarket}</p>
                        <p class="text-sm text-blue-700 mt-1">Sell here for maximum profit</p>
                    </div>
                    <div class="p-4 bg-yellow-50 border-l-4 border-yellow-500 rounded-r-xl">
                        <p class="font-semibold text-yellow-800">💡 Recommendation</p>
                        <p class="text-sm text-yellow-700 mt-1">Hold your stock for better prices this week</p>
                    </div>
                `;
            } else {
                recommendationHTML = `
                    <div class="p-4 bg-red-50 border-l-4 border-red-500 rounded-r-xl">
                        <p class="font-semibold text-red-800">📉 Price Expected to Fall</p>
                        <p class="text-sm text-red-700 mt-1">Prices may decrease by ${Math.abs(priceChange).toFixed(1)}% in next 7 days</p>
                    </div>
                    <div class="p-4 bg-blue-50 border-l-4 border-blue-500 rounded-r-xl">
                        <p class="font-semibold text-blue-800">🏪 Best Market: ${bestMarket}</p>
                        <p class="text-sm text-blue-700 mt-1">Sell now for best available price</p>
                    </div>
                    <div class="p-4 bg-yellow-50 border-l-4 border-yellow-500 rounded-r-xl">
                        <p class="font-semibold text-yellow-800">💡 Recommendation</p>
                        <p class="text-sm text-yellow-700 mt-1">Consider selling immediately to avoid losses</p>
                    </div>
                `;
            }
            
            document.getElementById('recommendationContent').innerHTML = recommendationHTML;
        }

        function updateMarketTable() {
            const markets = [
                { name: 'Sangli APMC Market Yard', tomato: 1250, potato: 920, onion: 2850, cabbage: 680 },
                { name: 'Miraj Vegetable Market', tomato: 1180, potato: 890, onion: 2780, cabbage: 650 },
                { name: 'Atpadi Wholesale Market', tomato: 1320, potato: 950, onion: 2920, cabbage: 720 },
                { name: 'Bhivghat Vegetable Market', tomato: 1150, potato: 870, onion: 2700, cabbage: 620 },
                { name: 'Palus APMC Market', tomato: 1280, potato: 910, onion: 2890, cabbage: 690 }
            ];
            
            let tableHTML = '';
            markets.forEach(market => {
                tableHTML += `
                    <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="py-3 px-4 font-medium">${market.name}</td>
                        <td class="py-3 px-4 font-semibold text-primary-600">₹${market.tomato}</td>
                        <td class="py-3 px-4">₹${market.potato}</td>
                        <td class="py-3 px-4">₹${market.onion}</td>
                        <td class="py-3 px-4">₹${market.cabbage}</td>
                        <td class="py-3 px-4">
                            <button class="text-primary-600 hover:underline font-medium">View Details</button>
                        </td>
                    </tr>
                `;
            });
            
            document.getElementById('marketTableBody').innerHTML = tableHTML;
        }
    </script>
</body>
</html>

