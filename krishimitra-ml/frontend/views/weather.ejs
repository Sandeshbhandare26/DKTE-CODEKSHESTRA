<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weather - KrishiMitra 2.0</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#DCFCE7', 100: '#BBF7D0', 200: '#86EFAC', 300: '#4ADE80', 400: '#22C55E', 500: '#16A34A', 600: '#15803D', 700: '#166534', 800: '#14532D', 900: '#052E16' },
                        accent: { 50: '#FEF9C3', 100: '#FEF08A', 200: '#FDE047', 300: '#FACC15', 400: '#EAB308', 500: '#CA8A04' }
                    },
                    fontFamily: { inter: ['Inter', 'sans-serif'], poppins: ['Poppins', 'sans-serif'] }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-poppins { font-family: 'Poppins', sans-serif; }
        .sidebar { transition: all 0.3s ease; }
        .sidebar-item:hover { background: linear-gradient(90deg, rgba(22, 101, 52, 0.1) 0%, transparent 100%); }
        .sidebar-item.active { background: linear-gradient(90deg, #166534 0%, #22C55E 100%); color: white; }
    </style>
</head>
<body class="font-inter bg-gray-50">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="sidebar w-64 bg-white shadow-xl fixed h-full z-40">
            <div class="p-6 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <span class="text-4xl">🌾</span>
                    <span class="font-poppins font-bold text-xl text-primary-700">KrishiMitra</span>
                </div>
            </div>
            <nav class="p-4 space-y-2">
                <a href="/dashboard" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                    Dashboard
                </a>
                <a href="/analysis" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Crop Analysis
                </a>
                <a href="/weather" class="sidebar-item active flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
                    Weather
                </a>
                <a href="/market" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    Market Prices
                </a>
                <a href="/history" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    History
                </a>
                <a href="/profile" class="sidebar-item flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 font-medium transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Profile
                </a>
            </nav>
            <div class="absolute bottom-0 left-0 right-0 p-4">
                <a href="/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-red-600 font-medium hover:bg-red-50 transition-all duration-300">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="ml-64 flex-1 p-8">
            <header class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="font-poppins font-bold text-3xl text-gray-800">Weather Insights</h1>
                    <p class="text-gray-500 mt-1">Real-time weather data and AI-powered risk alerts</p>
                </div>
                <div class="flex items-center gap-4">
                    <select class="px-4 py-2 border-2 border-gray-200 rounded-xl focus:border-primary-500 outline-none">
                        <option>Maharashtra</option>
                        <option>Punjab</option>
                        <option>Uttar Pradesh</option>
                        <option>Gujarat</option>
                    </select>
                </div>
            </header>

            <!-- Current Weather -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                <div class="lg:col-span-2 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl p-8 text-white">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-blue-100 mb-1">Current Location</p>
                            <h2 class="font-poppins font-bold text-2xl mb-2">Sangli, Maharashtra</h2>
                            <p class="text-blue-100">Tuesday, March 2026</p>
                        </div>
                        <div class="text-center">
                            <span class="text-8xl">☀️</span>
                            <p class="text-4xl font-bold">28°C</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-4 gap-4 mt-8">
                        <div class="text-center bg-white/10 rounded-xl p-4">
                            <p class="text-blue-100 text-sm">Humidity</p>
                            <p class="font-bold text-lg">65%</p>
                        </div>
                        <div class="text-center bg-white/10 rounded-xl p-4">
                            <p class="text-blue-100 text-sm">Wind</p>
                            <p class="font-bold text-lg">12 km/h</p>
                        </div>
                        <div class="text-center bg-white/10 rounded-xl p-4">
                            <p class="text-blue-100 text-sm">Rain</p>
                            <p class="font-bold text-lg">10%</p>
                        </div>
                        <div class="text-center bg-white/10 rounded-xl p-4">
                            <p class="text-blue-100 text-sm">UV Index</p>
                            <p class="font-bold text-lg">6</p>
                        </div>
                    </div>
                </div>

                <!-- AI Alerts -->
                <div class="bg-white rounded-2xl p-6 shadow-lg">
                    <h3 class="font-poppins font-bold text-xl text-gray-800 mb-4">🤖 AI Alerts</h3>
                    <div class="space-y-4">
                        <div class="p-4 bg-yellow-50 border-l-4 border-yellow-500 rounded-r-xl">
                            <p class="font-semibold text-yellow-800">Pest Risk: High</p>
                            <p class="text-sm text-yellow-700">Humidity is optimal for fungal growth. Consider preventive spray.</p>
                        </div>
                        <div class="p-4 bg-blue-50 border-l-4 border-blue-500 rounded-r-xl">
                            <p class="font-semibold text-blue-800">Irrigation Insight</p>
                            <p class="text-sm text-blue-700">Soil moisture is adequate. Skip irrigation today.</p>
                        </div>
                        <div class="p-4 bg-green-50 border-l-4 border-green-500 rounded-r-xl">
                            <p class="font-semibold text-green-800">Optimal Sowing</p>
                            <p class="text-sm text-green-700">Weather conditions are ideal for tomato sowing.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 7-Day Forecast Chart -->
            <div class="bg-white rounded-2xl p-8 shadow-lg mb-8">
                <h3 class="font-poppins font-bold text-xl text-gray-800 mb-6">7-Day temperature Forecast</h3>
                <canvas id="weatherChart" height="100"></canvas>
            </div>

            <!-- Hourly Forecast -->
            <div class="bg-white rounded-2xl p-8 shadow-lg">
                <h3 class="font-poppins font-bold text-xl text-gray-800 mb-6">Hourly Forecast</h3>
                <div class="flex gap-4 overflow-x-auto pb-4">
                    <div class="flex-shrink-0 text-center p-4 bg-gray-50 rounded-xl">
                        <p class="text-gray-500 text-sm">Now</p>
                        <p class="text-3xl my-2">☀️</p>
                        <p class="font-bold">28°</p>
                    </div>
                    <div class="flex-shrink-0 text-center p-4 bg-gray-50 rounded-xl">
                        <p class="text-gray-500 text-sm">1 PM</p>
                        <p class="text-3xl my-2">☀️</p>
                        <p class="font-bold">29°</p>
                    </div>
                    <div class="flex-shrink-0 text-center p-4 bg-gray-50 rounded-xl">
                        <p class="text-gray-500 text-sm">2 PM</p>
                        <p class="text-3xl my-2">⛅</p>
                        <p class="font-bold">28°</p>
                    </div>
                    <div class="flex-shrink-0 text-center p-4 bg-gray-50 rounded-xl">
                        <p class="text-gray-500 text-sm">3 PM</p>
                        <p class="text-3xl my-2">⛅</p>
                        <p class="font-bold">27°</p>
                    </div>
                    <div class="flex-shrink-0 text-center p-4 bg-gray-50 rounded-xl">
                        <p class="text-gray-500 text-sm">4 PM</p>
                        <p class="text-3xl my-2">🌧️</p>
                        <p class="font-bold">25°</p>
                    </div>
                    <div class="flex-shrink-0 text-center p-4 bg-gray-50 rounded-xl">
                        <p class="text-gray-500 text-sm">5 PM</p>
                        <p class="text-3xl my-2">🌧️</p>
                        <p class="font-bold">24°</p>
                    </div>
                    <div class="flex-shrink-0 text-center p-4 bg-gray-50 rounded-xl">
                        <p class="text-gray-500 text-sm">6 PM</p>
                        <p class="text-3xl my-2">☁️</p>
                        <p class="font-bold">23°</p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Weather Chart
        const ctx = document.getElementById('weatherChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Temperature (°C)',
                    data: [26, 28, 24, 27, 25, 26, 28],
                    borderColor: '#166534',
                    backgroundColor: 'rgba(22, 101, 52, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: false, min: 20, max: 35 }
                }
            }
        });
    </script>
</body>
</html>

