<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Disease Result - KrishiMitra</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            text-align: center;
            background: linear-gradient(135deg, #1a5f1a 0%, #2d8b2d 100%);
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .card {
            background: white;
            border-radius: 15px;
            padding: 40px;
            max-width: 400px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        
        h2 {
            color: #1a5f1a;
            font-size: 2rem;
            margin-bottom: 30px;
        }
        
        .result {
            margin: 30px 0;
        }
        
        .disease {
            font-size: 1.8rem;
            color: #d32f2f;
            font-weight: bold;
            margin-bottom: 15px;
        }
        
        .confidence {
            font-size: 1.2rem;
            color: #388e3c;
        }
        
        .confidence-bar {
            width: 100%;
            height: 30px;
            background: #e0e0e0;
            border-radius: 15px;
            margin: 15px 0;
            overflow: hidden;
        }
        
        .confidence-fill {
            height: 100%;
background: linear-gradient(90deg, #4caf50, #8bc34a);
            border-radius: 15px;
            transition: width 0.5s;
        }
        
        a {
            display: inline-block;
            padding: 15px 30px;
            background: #1a5f1a;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            margin-top: 20px;
        }
        
        a:hover {
            background: #2d8b2d;
            transform: translateY(-2px);
        }
        
        .icon {
            font-size: 4rem;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon">🔬</div>
        <h2>Disease Detection Result</h2>
        
        <div class="result">
            <p class="disease"><%= data.disease %></p>
            <p class="confidence">Confidence: <%= data.confidence %>%</p>
            <div class="confidence-bar">
                <div class="confidence-fill" style="width: <%= data.confidence %>%"></div>
        </div>
        
        <a href="/">Back to Home</a>
    </div>
</body>
</html>
